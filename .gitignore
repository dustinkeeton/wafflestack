.DS_Store

# self-render output (`node installer/cli.mjs render`) — consuming projects commit
# these; in the toolkit repo they are generated-only. See .waffle.yaml.
.claude/agents/
.claude/skills/
.claude/worktrees/
.codex/
.agents/
# The github-workflow bundle self-renders CI workflows here; keep them untracked —
# committing the doctor workflow would add always-failing CI to this repo (the lock is
# gitignored, so doctor would exit 1 on a missing lock), the label-hook workflow would
# arm a live label→harness dispatch on this repo, and pushing either needs the `workflow`
# credential scope. CI for this repo itself is a separate, deferred issue.
.github/workflows/waffle-doctor.yml
.github/workflows/waffle-label-hook.yml
.waffle.lock.json
.waffle.local.yaml

# Obsidian
.obsidian/